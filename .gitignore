# .NET build artifacts
**/bin/
**/obj/
*.user
*.suo
*.cache
TestResults/
coverage/

# Logs and per-run temp data
*.log
**/logs/
**/App_Data/temp/
**/temp/
tmp/
temp-test/

# LibreOffice bundle and deployment artifacts (generated at bundle/deploy time, never committed)
FileConversionApi/LibreOffice/
FileConversionApi/libreoffice-profile-template/
FileConversionApi/deployment/LibreOffice/
FileConversionApi/deploy/
deploy/

# Bundled Node engine binaries (staged at deploy time by deploy.ps1 Copy-NodeEngineBundle).
# The committed source of truth stays tracked: engine/pdf-to-html.mjs, engine/package.json,
# engine/package-lock.json. Only the runtime binaries are ignored.
node_modules/
FileConversionApi/engine/node/
FileConversionApi/engine/node_modules/

# Sample files (user data). Ignore directory *contents* (not the directory itself) so the two
# tracked fixtures below can be re-included; git cannot re-include a file whose parent directory
# is excluded by a trailing-slash rule, and on a case-insensitive filesystem `Samples/` also
# matches `samples/`.
samples/*
Samples/*
# Tracked fidelity baseline + fixture inherited by the QA suite.
!samples/template.html
!samples/template.docx

# Secrets (never commit private keys or environment files)
.env
.env.*
ssl/
*.key
*.cert
*.crt
*.pem
*.pfx

# Local conversion output (fixture-conversion playground; never shipped)
/out/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS-generated files
.DS_Store
Thumbs.db
ehthumbs.db

# AI assistant / agent artifacts and local-only planning (kept out of the repo by intent)
.claude/
.cursor/
.copilot/
.aider*
MEMORY.md
**/MEMORY.md
CLAUDE.md
AGENTS.md
.planning/

# Local-only scratch and throwaway workspaces (not shipped)
spike-driver/
artifacts/
